# ==========================================
# TROXZYMD - ENVIRONMENT CONFIGURATION
# ==========================================
# Jangan pernah share/upload file ini ke publik (GitHub dsb)
# Tambahkan .env ke .gitignore

# ---------- BOT IDENTITY ----------
BOT_NAME=TroxzyMD
OWNER_NAME=Troxzy
OWNER_NUMBER=
TELEGRAM_OWNER=t.me/SoloBanNoTrash
# Link channel WhatsApp kamu, format: https://whatsapp.com/channel/xxxxx
# WAJIB diisi sebelum deploy — sistem registrasi wajib mengarahkan user ke sini
CHANNEL_LINK=https://whatsapp.com/channel/0029Vb8IEPU4IBh7dGCrXB1W

# ---------- SESSION MODE ----------
# pairing = login pakai kode 8 digit (disarankan)
# qr = login pakai scan QR
SESSION_METHOD=qr

# ---------- AI CONFIGURATION ----------
# Alias model HARUS persis seperti di freetheai.xyz/models (format: prefix/nama-model)
AI_BASE_URL=https://api.freetheai.xyz/v1
AI_API_KEY=
AI_MODEL=glm/glm-5.2
# Model cadangan otomatis jika GLM kena rate limit/depleted (lihat README bagian AI)
AI_FALLBACK_MODEL=opc/deepseek-v4-flash-free
AI_TTS_MODEL=mim/mimo-v2.5-tts
AI_STT_MODEL=mim/mimo-v2.5-asr
AI_IMAGE_MODEL=eve/gpt-image-2
# Model vision untuk .analisagambar. PERINGATAN: per awal Juli 2026 belum ada
# alternatif non-vova yang terkonfirmasi mendukung vision di FreeTheAi.
# Set ke "disabled" untuk mematikan fitur .analisagambar jika tidak mau pakai vova sama sekali.
AI_VISION_MODEL=vova/gemini-2.5-flash

# ---------- PAYMENT (QRIS MANUAL) ----------
QRIS_MERCHANT_NAME=Troxzy Store
# Taruh file gambar QR kamu sendiri di: assets/qris.jpg (untuk fallback manual)

# ---------- PAYMENT OTOMATIS (Midtrans, opsional) ----------
# Kosongkan/biarkan placeholder ini kalau belum daftar Midtrans — sistem
# otomatis pakai QR manual + approve owner seperti biasa, TIDAK ada bug.
# Daftar gratis di https://midtrans.com (cukup KTP untuk individu)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
# Taruh file gambar QR kamu sendiri di: assets/qris.jpg

# ---------- SERVER (untuk keep-alive Pterodactyl) ----------
PORT=2007

# ---------- MODE ----------
PUBLIC_MODE=true
